FRONTEND_PORT=3000
BACKEND_PORT=4000
NODE_ENV=production
# Required for backend token signing. Generate a strong local value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=

# Optional server-side pepper added before Argon2id password hashing.
# Changing this after users register will invalidate existing passwords.
PASSWORD_PEPPER=

# Optional comma-separated browser origins allowed to call the backend directly.
# Leave empty for Docker/nginx same-origin production traffic.
ALLOWED_ORIGINS=

# Number of trusted reverse proxies in front of Express. Docker nginx is one hop.
TRUST_PROXY=1

# Optional frontend dev/build overrides. Defaults use same-origin /api and /ws.
# Vite dev also proxies /api and /ws to VITE_DEV_BACKEND_URL or localhost:4000.
VITE_DEV_BACKEND_URL=http://localhost:4000
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
