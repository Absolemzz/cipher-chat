FRONTEND_PORT=3000
BACKEND_PORT=4000
# Required for backend token signing. Generate a strong local value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=

# Optional server-side pepper added before Argon2id password hashing.
# Changing this after users register will invalidate existing passwords.
PASSWORD_PEPPER=